# Cloistr Email - Production Environment Configuration
# Copy this file to .env.production and fill in actual values
# NEVER commit .env.production to version control!

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# HTTP server address
LISTEN_ADDR=:8080

# Prometheus metrics server address
METRICS_ADDR=:9090

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Environment: development, staging, production
ENVIRONMENT=production

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string
# Format: postgres://user:password@host:port/database?sslmode=require
DATABASE_URL=postgres://email_user:SECURE_PASSWORD_HERE@localhost:5432/cloistr_email?sslmode=require

# =============================================================================
# REDIS (Session Storage)
# =============================================================================

# Redis connection string
# Format: redis://:password@host:port/db
REDIS_URL=redis://:SECURE_PASSWORD_HERE@localhost:6379/0

# =============================================================================
# SMTP OUTBOUND
# =============================================================================

# Delivery mode: relay, direct, or hybrid
# - relay: Send through configured relay server (SMTP_HOST)
# - direct: Deliver directly via MX lookup
# - hybrid: Direct for known domains, relay for others
SMTP_DELIVERY_MODE=direct

# Relay server (only used in relay/hybrid mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# =============================================================================
# SMTP INBOUND
# =============================================================================

# Enable inbound SMTP server
SMTP_INBOUND_ENABLED=true

# SMTP server listen address (usually :25)
SMTP_INBOUND_ADDR=:25

# Primary domain for this mail server
SMTP_INBOUND_DOMAIN=coldforge.xyz

# All accepted domains (comma-separated)
SMTP_INBOUND_DOMAINS=coldforge.xyz,mail.coldforge.xyz

# TLS certificate paths
SMTP_INBOUND_TLS_CERT=/etc/letsencrypt/live/mail.coldforge.xyz/fullchain.pem
SMTP_INBOUND_TLS_KEY=/etc/letsencrypt/live/mail.coldforge.xyz/privkey.pem

# =============================================================================
# DKIM (Email Signing)
# =============================================================================

# DKIM signing domain
DKIM_DOMAIN=coldforge.xyz

# DKIM selector (DNS: selector._domainkey.domain)
DKIM_SELECTOR=mail

# DKIM private key (PEM format)
# Generate with: ./scripts/generate-dkim-keys.sh
DKIM_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
PASTE_YOUR_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----"

# =============================================================================
# RATE LIMITING
# =============================================================================

# Max connections per IP per minute
RATE_LIMIT_CONNECTIONS_PER_MINUTE=30

# Max messages per IP per hour
RATE_LIMIT_MESSAGES_PER_HOUR=100

# Block duration for rate-limited IPs
RATE_LIMIT_BLOCK_DURATION=1h

# Whitelisted IPs (comma-separated, CIDR notation supported)
RATE_LIMIT_WHITELIST=127.0.0.1,10.0.0.0/8

# =============================================================================
# NOSTR INTEGRATION
# =============================================================================

# nsecbunker relay URL for NIP-46 authentication
NSECBUNKER_RELAY_URL=wss://relay.coldforge.xyz

# Identity service URL (optional)
IDENTITY_SERVICE_URL=

# =============================================================================
# RELAY PREFERENCES (cloistr-common integration)
# =============================================================================

# Internal discovery service URL
DISCOVERY_INTERNAL=

# Comma-separated relay list for direct querying
RELAY_LIST=

# External discovery service URL
DISCOVERY_EXTERNAL=

# Use Cloistr services as fallback
USE_CLOISTR_FALLBACK=true

# Cache TTL for relay preferences
RELAY_PREFS_CACHE_TTL=1h

# =============================================================================
# CACHING
# =============================================================================

# NIP-05 lookup cache TTL
NIP05_CACHE_TTL=24h

# MX record cache TTL
MX_CACHE_TTL=1h

# =============================================================================
# SECURITY
# =============================================================================

# Allowed CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://mail.coldforge.xyz,https://email.coldforge.xyz

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=GENERATE_A_SECURE_RANDOM_STRING

# JWT signing key (generate with: openssl rand -hex 32)
JWT_SECRET=GENERATE_A_SECURE_RANDOM_STRING

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable NIP-07 client-side encryption
ENABLE_NIP07=true

# Enable Nostr email signing (RFC-002)
ENABLE_NOSTR_SIGNING=true

# Enable inbound signature verification
ENABLE_SIGNATURE_VERIFICATION=true

# =============================================================================
# FUTURE: LIGHTNING SPAM CONTROL (RFC-002 Phase 4)
# =============================================================================

# Enable Lightning Network spam control
# LIGHTNING_ENABLED=false

# LUD-16 Lightning address for receiving payments
# LIGHTNING_ADDRESS=

# Payment required to send email (sats)
# LIGHTNING_PAYMENT_REQUIRED=0

# =============================================================================
# MONITORING
# =============================================================================

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable debug endpoints (disable in production!)
DEBUG_ENDPOINTS=false
